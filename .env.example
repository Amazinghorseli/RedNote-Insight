# ============================================================
# 🎯 RedNote Insight — Environment Configuration
# ============================================================
# Setup:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your API key below
#   3. Get a free key at: https://siliconflow.cn (supports DeepSeek)
#
# All fields are compatible with any OpenAI-format API provider:
#   - SiliconFlow (硅基流动):  https://api.siliconflow.cn/v1
#   - Alibaba Bailian (阿里云百炼): https://dashscope.aliyuncs.com/compatible-mode/v1
#   - DeepSeek Official:     https://api.deepseek.com/v1
#   - OpenAI:                https://api.openai.com/v1
# ============================================================

# ===== LLM Configuration =====
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_API_KEY=your_api_key_here
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# ===== Embedding Model =====
# For semantic search (Chinese-optimized)
EMBEDDING_MODEL=BAAI/bge-m3

# ===== Reranker Model =====
# Cross-Encoder for relevance scoring
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
