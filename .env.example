# 🎯 小红书爆款雷达 — 配置模板
# 复制为 .env 并填入真实值：
#   cp .env.example .env

# ===== LLM 配置 =====
# 兼容 OpenAI API 格式的提供商地址（SiliconFlow / 阿里云百炼 / 火山引擎等）
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# API 密钥
OPENAI_API_KEY=your_api_key_here
# 主模型：用于分析、推理、报告生成（推荐 DeepSeek-V4-Flash）
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# ===== Embedding 模型 =====
# 文本向量化模型，用于语义检索
EMBEDDING_MODEL=BAAI/bge-m3

# ===== Reranker（重排序） =====
# Cross-Encoder 重排序模型，提升检索精度
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
